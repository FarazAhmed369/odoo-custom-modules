<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="course_list_view" model="ir.ui.view">
      <field name="name">Course List</field>
      <field name="model">faraz_std.course</field>
      <field name="arch" type="xml">
        <list string="Course">
          <field name="name"/>
          <field name="id"/>
        </list>
      </field>
    </record>


    <record id="course_form_view" model="ir.ui.view">
      <field name="name">Course Form</field>
      <field name="model">faraz_std.course</field>
      <field name="arch" type="xml">
        <form string="Course">
          <group>
            <field name="name"/>
          </group>
        </form>
      </field>
    </record>

    <record id="action_course_list" model="ir.actions.act_window">
        <field name="name">Course List</field>
        <field name="res_model">faraz_std.course</field>
        <field name="view_mode">list,form</field>
    </record>

  <menuitem id="menu_course_list"
            name="Course List"
            parent="menu_faraz_root_sub"
            action="action_course_list"
            sequence="2"
  />
</odoo>