<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="school_list_view" model="ir.ui.view">
      <field name="name">School List</field>
      <field name="model">faraz_std.school</field>
      <field name="arch" type="xml">
        <list string="School">
          <field name="name"/>
          <field name="id"/>
        </list>
      </field>
    </record>


    <record id="school_form_view" model="ir.ui.view">
      <field name="name">School Form</field>
      <field name="model">faraz_std.school</field>
      <field name="arch" type="xml">
        <form string="School">
          <group>
            <field name="name"/>
            <field name="address"/>
            <field name="std_fees"/>
            <field name="student_list"/>
            <field name="ref_field_id"/>
            <field name="invoice_id"/>
            <field name="invoice_user_id"/>
            <field name="invoice_date"/>
          </group>
        </form>
      </field>
    </record>

    <record id="action_school_list" model="ir.actions.act_window">
        <field name="name">School List</field>
        <field name="res_model">faraz_std.school</field>
        <field name="view_mode">list,form</field>
    </record>

  <menuitem id="menu_faraz_root"
            name="Student List"
            sequence="-100"
  />

  <menuitem id="menu_faraz_root_sub"
            name="weblearns"
            parent="menu_faraz_root"
            sequence="1"
  />

  <menuitem id="menu_school_list"
            name="School List"
            parent="menu_faraz_root_sub"
            action="action_school_list"
            sequence="2"
  />
</odoo>