    <record id="custom_paper_format" model="report.paperformat">
        <field name="name">Custom Paper Format</field>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_right">5</field>
        <field name="margin_left">5</field>
        <field name="header_spacing">35</field>
        <field name="dpi">90</field>
    </record>

    <record id="student_profile_report_template" model="ir.actions.report">
        <field name="name">Student Card</field>
        <field name="model">faraz_std.student</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">qweb_pdf_report_example.student_report_template</field>
        <field name="report_file">qweb_pdf_report_example.student_report_template</field>
        <field name="print_report_name">'Student-Card'</field>
        <field name="binding_model_id" ref="faraz_std.model_faraz_std_student"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="custom_paper_format"/>
    </record>

</odoo>