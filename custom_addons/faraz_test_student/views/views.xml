<odoo>
  <data>

    <record id="test_student_list_view" model="ir.ui.view">
      <field name="name">test.student.list.view</field>
      <field name="model">faraz.test_student</field>
      <field name="arch" type="xml">
        <list string="Test Students">
          <field name="name"/>
          <field name="age"/>
        </list>
      </field>
    </record>

    <record id="test_student_form_view" model="ir.ui.view">
      <field name="name">test.student.form.view</field>
      <field name="model">faraz.test_student</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <group>
              <field name="name"/>
              <field name="age"/>
              <field name="email"/>
              <field name="remarks"/>
            </group>
          </group>
        </form>
      </field>
    </record>

    <record id="test_student_action" model="ir.actions.act_window">
      <field name="name">Test Students</field>
      <field name="res_model">faraz.test_student</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem
            id="test_student_menu_root"
            name="Testing"
    />
    <menuitem
            id="test_student_menu_child"
            name="Test Students"
            parent="test_student_menu_root"
            action="test_student_action"/>



  </data>
</odoo>
