<odoo>
  <record id="view_course_form" model="ir.ui.view">
    <field name="name">Course Form</field>
    <field name="model">uni_marksheet.course</field>
    <field name="arch" type="xml">
      <form string="Course">
        <sheet>
          <group>
            <field name="name"/>
            <field name="code"/>
            <field name="credit_hours"/>
            <field name="max_marks"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_course_tree" model="ir.ui.view">
    <field name="name">Course List</field>
    <field name="model">uni_marksheet.course</field>
    <field name="arch" type="xml">
      <tree string="Courses">
        <field name="name"/>
        <field name="code"/>
        <field name="credit_hours"/>
      </tree>
    </field>
  </record>

  <record id="action_course" model="ir.actions.act_window">
    <field name="name">Courses</field>
    <field name="res_model">uni_marksheet.course</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_course" name="Courses" parent="menu_uni_root" action="action_course"/>
</odoo>
