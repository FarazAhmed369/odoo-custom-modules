<?xml version="1.0" encoding="utf-8" ?>
<odoo>


  <record id="student_list_view" model="ir.ui.view">
    <field name="name">student.list.view</field>
    <field name="model">faraz_std.student</field>
    <field name="arch" type="xml">
      <list>
          <field name="name"/>
          <field name="id"/>
          <field name="school_id"/>
          <field name="std_fees"/>
          <field name="discount"/>
          <field name="disc_fees"/>
          <field name="amount"/>
          <field name="my_currency_id"/>

          <!--        <field name="name"/>-->
<!--        <field name="roll_number"/>-->
<!--        <field name="is_paid"/>-->
      </list>
    </field>
  </record>

